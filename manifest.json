{
  "manifest_version": 3,
  "name": "QuietJunk",
  "description": "Silently clears your spam. No noise. No clutter.",
  "version": "0.0.3",
  "author": "Peter",
  "browser_specific_settings": {
    "gecko": {
      "id": "quietjunk@addons.thunderbird.net",
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "accountsRead",
    "alarms",
    "messagesRead",
    "messagesUpdate",
    "storage"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ],
    "type": "module"
  },
  "options_ui": {
    "page": "ui/options.html",
    "open_in_tab": false
  }
}
