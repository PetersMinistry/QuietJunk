{
  "manifest_version": 3,
  "name": "QuietJunk",
  "description": "Silently clears your spam. No noise. No clutter.",
  "version": "0.1.0",
  "author": "Peter",
  "browser_specific_settings": {
    "gecko": {
      "id": "quietjunk@addons.thunderbird.net",
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "16": "icons/quietjunk-16.svg",
    "32": "icons/quietjunk-32.svg",
    "64": "icons/quietjunk-64.svg"
  },
  "permissions": [
    "accountsRead",
    "messagesRead",
    "messagesUpdate",
    "storage"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ],
    "type": "module"
  },
  "options_ui": {
    "page": "ui/options.html",
    "open_in_tab": false,
    "browser_style": true
  }
}
